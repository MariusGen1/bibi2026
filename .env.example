# Supabase — create a project at https://supabase.com, then paste these
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — https://console.anthropic.com
ANTHROPIC_API_KEY=
# Optional override; defaults to claude-opus-4-7
ANTHROPIC_MODEL=claude-opus-4-7

# Twilio — leave blank to use mock SMS (logs to console + shows on-screen preview)
# Trial accounts can only send to verified numbers; verify your demo phone first.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Hardcoded demo owner password (so a curious link-clicker can't see private data)
OWNER_DEMO_PASSWORD=luigi

# Secret used to HMAC-sign the owner session cookie. Must be ≥16 chars in
# production (e.g. `openssl rand -hex 32`). Dev falls back to a default.
SESSION_SECRET=
